# Twilio Credentials
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# MongoDB Atlas
# Get this from https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/kissanlink?retryWrites=true&w=majority

# Server
PORT=8080

# Render Keep-alive (set to your Render URL after deploying, e.g. https://kissanlink.onrender.com)
RENDER_URL=
KEEPALIVE_INTERVAL=300

